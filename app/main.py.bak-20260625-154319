# ── Request models ────────────────────────────────────────────────
class CandidateRequest(BaseModel):
    description: str

class GuidanceRequest(BaseModel):
    kb_id: str


# ── KB docx parser ────────────────────────────────────────────────
_SKIP_PREFIXES  = ("kb id:", "guidance troubleshoot:")
_KNOWN_SECTIONS = ("user experience", "symptoms:", "cause:", "resolution:")
_OPTION_RE      = re.compile(r"^option\s*\d+", re.IGNORECASE)

# Manual enumerator patterns — used only as a fallback when a KB doc uses
# typed markers ("a.", "i.", "-") instead of Word's built-in list numbering.
# Roman is checked before alpha so "ii."/"iv." are not mistaken for letters.
# Letter 'i' is excluded from the alpha pattern to avoid clashing with roman i.
_RE_NUM    = re.compile(r"^\(?\d+[.\)]\s*")
_RE_ROMAN  = re.compile(r"^\(?(x|ix|v?i{1,3}|iv)[.\)]\s+", re.IGNORECASE)
_RE_ALPHA  = re.compile(r"^\(?[a-hj-z][.\)]\s*", re.IGNORECASE)
_RE_BULLET = re.compile(r"^[\u2022\u25CF\u25AA\u25E6\-\*]\s+")


def _strip_marker(text: str):
    """Strip a leading typed enumerator. Returns (clean_text, marker_level|None)."""
    if _RE_BULLET.match(text):
        return _RE_BULLET.sub("", text, count=1).strip(), 1
    if _RE_ROMAN.match(text):
        return _RE_ROMAN.sub("", text, count=1).strip(), 2
    if _RE_ALPHA.match(text):
        return _RE_ALPHA.sub("", text, count=1).strip(), 1
    if _RE_NUM.match(text):
        return _RE_NUM.sub("", text, count=1).strip(), 0
    return text, None


def _list_level(para, text: str):
    """
    Determine nesting level (0=main, 1=sub, 2=sub-sub) for a list paragraph,
    using these signals in priority order:
      1. Word numbering level (numPr/ilvl)  — authoritative when present
      2. Left indent, bucketed at ~0.25in per level
      3. A typed marker at the start of the text (a. / i. / bullet)
    Returns (level:int in 0..2, clean_text:str with any redundant marker removed).
    """
    # 1. Word list level
    try:
        pPr = para._p.pPr
        if pPr is not None and pPr.numPr is not None and pPr.numPr.ilvl is not None:
            lvl = int(pPr.numPr.ilvl.val)
            clean, _ = _strip_marker(text)
            return max(0, min(lvl, 2)), clean
    except Exception:
        pass

    # 2. Indent bucket
    try:
        li = para.paragraph_format.left_indent
        if li is not None and li.inches and li.inches > 0:
            lvl = int(round(li.inches / 0.25)) - 1
            clean, _ = _strip_marker(text)
            return max(0, min(lvl, 2)), clean
    except Exception:
        pass

    # 3. Typed marker
    clean, mlvl = _strip_marker(text)
    if mlvl is not None:
        return mlvl, clean
    return 0, text


def _parse_kb_docx(doc_bytes: bytes) -> dict:
    doc = python_docx.Document(BytesIO(doc_bytes))

    title, environment, note = "", "", ""
    sections: list = []
    current_section = None
    first_normal = True

    for para in doc.paragraphs:
        text = para.text.strip()
        if not text:
            continue

        tl      = text.lower()
        is_list = para.style.name == "List Paragraph"

        if any(tl.startswith(p) for p in _SKIP_PREFIXES):
            continue

        if is_list:
            if current_section is None:
                current_section = {"heading": "Resolution Steps", "steps": []}
                sections.append(current_section)
            level, clean = _list_level(para, text)
            # Each step is an object carrying its hierarchy level so the agent
            # can render main / sub / sub-sub without guessing or merging.
            current_section["steps"].append({"text": clean, "level": level})
            continue

        if first_normal:
            title = text
            first_normal = False
            continue

        if tl.startswith("environment:"):
            environment = text.split(":", 1)[1].strip()
            continue

        if tl.startswith("note:"):
            note = text.split(":", 1)[1].strip()
            continue

        # Structural dividers (symptoms, cause, resolution headers) — skip them
        # and the Normal paragraph that immediately follows each one is their body text,
        # which is also skipped by falling through to the end of this loop.
        if any(tl.startswith(h) for h in _KNOWN_SECTIONS):
            current_section = None
            continue

        if _OPTION_RE.match(tl):
            current_section = {"heading": text.rstrip(":"), "steps": []}
            sections.append(current_section)

    return {"title": title, "environment": environment, "note": note, "sections": sections}


# ── Helper ────────────────────────────────────────────────────────
def compute_spread(scores: list[float]) -> str:
    """
    'high' (ambiguous → ask follow-up) when ANY of:
      1. Weak absolute match:  top score below HIGH_CONFIDENCE
      2. Weak dominance:       gap between #1 and #2 below SPREAD_THRESHOLD

    'low' (confident → skip follow-up) only when BOTH hold:
      1. Top score >= HIGH_CONFIDENCE   (strong absolute match)
      2. Gap >= SPREAD_THRESHOLD        (clear winner over #2)
    """
    if not scores:
        return "low"

    weak_absolute  = scores[0] < HIGH_CONFIDENCE
    weak_dominance = len(scores) > 1 and (scores[0] - scores[1]) < SPREAD_THRESHOLD

    if weak_absolute or weak_dominance:
        return "high"
    return "low"

def dedupe_by_kb(rows):
    """Keep only the best-scoring chunk per kb_id, so the agent sees
    distinct KB articles (not multiple chunks of the same article)."""
    best = {}
    for row in rows:
        kb_id = row.get("kb_id", "")
        if kb_id not in best or row["score"] > best[kb_id]["score"]:
            best[kb_id] = row
    return sorted(best.values(), key=lambda c: c["score"], reverse=True)


# ── Symptom selection: rank by discriminating power ───────────────
#
# Goal: when spread == 'high', the agent must ask targeted follow-up
# questions. Instead of passing the full symptom list and leaving the
# choice to the LLM, we pre-select the 2-3 symptoms that best split
# the candidate set. We do this with two complementary signals:
#
#   1. Hybrid + semantic re-rank against the user description
#      — run each symptom as a mini semantic search against the
#        user description. Symptoms that are more *distinctive* from
#        what the user already said score higher (they add information).
#
#   2. Information-gain (mass-proximity-to-0.5)
#      — a symptom is most discriminating when it is present in some
#        candidates but not others, and when the probability mass of
#        the candidates that carry it is closest to 0.5. That way a
#        yes/no answer maximally splits the belief distribution.
#
# We combine these into a final score and return the top-k symptoms.

def _tfidf_like_vector(text: str) -> dict[str, float]:
    """
    Very lightweight bag-of-words TF vector over cleaned tokens.
    Used for cosine similarity between description and symptoms
    without needing an embedding API call.
    """
    tokens = re.findall(r"[a-z]+", text.lower())
    # Filter trivial stopwords
    STOP = {
        "a","an","the","is","it","in","on","of","to","and","or","for",
        "with","this","that","was","are","be","at","by","has","have",
        "had","not","but","from","as","do","did","will","would","can",
        "could","my","your","their","its","i","you","he","she","they",
        "we","our","no","so","if","when","how","what","which","where",
        "there","been","more","also","than","then","all","any","some",
        "been","were","should","may","might","over","after","before",
    }
    counts: dict[str, float] = {}
    for t in tokens:
        if t not in STOP and len(t) > 2:
            counts[t] = counts.get(t, 0.0) + 1.0
    norm = math.sqrt(sum(v * v for v in counts.values())) or 1.0
    return {k: v / norm for k, v in counts.items()}


def _cosine(a: dict[str, float], b: dict[str, float]) -> float:
    """Cosine similarity between two TF vectors (dicts)."""
    return sum(a.get(k, 0.0) * v for k, v in b.items())


def select_discriminating_symptoms(
    description: str,
    candidates: list[dict],
    top_k: int = 3,
) -> list[str]:
    """
    Given the user description and the top-N candidate KB articles,
    return the 2-3 symptoms that best discriminate between the
    candidates so the agent can frame targeted follow-up questions.

    Algorithm
    ---------
    For each symptom string across all candidates:

      a) Semantic relevance score  (rel):
         Cosine similarity between description and symptom text.
         High rel means the user's description already resonates with
         this symptom — useful signal that the symptom is live.

      b) Cross-candidate distinctiveness score  (dist):
         A symptom appearing in EVERY candidate offers no split
         power. A symptom appearing in only ONE candidate is very
         distinctive but may be too narrow. We reward symptoms that
         appear in a SUBSET of candidates (presence mass ≈ 0.5 of
         total score mass), maximising information gain.
         dist = 1 - |2 * mass_fraction - 1|
         (1.0 when the symptom's mass ≈ 50% of total, 0 when all or none)

      c) Final score = rel * 0.5 + dist * 0.5
         Both signals matter: we want symptoms the user's situation
         touches (rel) that also split the candidate set (dist).

    Deduplication: symptoms that are near-duplicates (cosine > 0.85)
    are collapsed — only the higher-scoring one survives.

    Returns up to `top_k` symptom strings, ordered best-first.
    """
    if not candidates:
        return []

    # Collect all unique symptom strings with their source candidate scores
    # symptom_sources: symptom_text -> list of candidate scores that carry it
    symptom_sources: dict[str, list[float]] = {}
    for cand in candidates:
        for sym in (cand.get("key_symptoms") or []):
            sym = sym.strip()
            if not sym:
                continue
            symptom_sources.setdefault(sym, []).append(float(cand["score"]))

    if not symptom_sources:
        logger.info("select_discriminating_symptoms: no symptoms found in candidates")
        return []

    total_score_mass = sum(c["score"] for c in candidates)
    desc_vec = _tfidf_like_vector(description)

    scored: list[tuple[float, str]] = []
    for sym_text, carrier_scores in symptom_sources.items():
        sym_vec = _tfidf_like_vector(sym_text)

        # a) relevance: cosine between description and symptom
        rel = _cosine(desc_vec, sym_vec)

        # b) distinctiveness: how close is carrier mass to 50% of total
        carrier_mass = sum(carrier_scores) / total_score_mass if total_score_mass > 0 else 0.0
        dist = 1.0 - abs(2.0 * carrier_mass - 1.0)

        final = rel * 0.5 + dist * 0.5
        scored.append((final, sym_text))

    # Sort descending by final score
    scored.sort(key=lambda x: -x[0])

    # Greedy deduplication: suppress near-duplicate symptoms
    selected: list[str] = []
    selected_vecs: list[dict[str, float]] = []
    for _, sym_text in scored:
        sym_vec = _tfidf_like_vector(sym_text)
        if any(_cosine(sym_vec, sv) > 0.85 for sv in selected_vecs):
            continue   # too similar to something already chosen
        selected.append(sym_text)
        selected_vecs.append(sym_vec)
        if len(selected) >= top_k:
            break

    logger.info(
        "select_discriminating_symptoms: %d symptoms -> %d selected (top_k=%d)",
        len(scored), len(selected), top_k,
    )
    for i, s in enumerate(selected):
        logger.info("  symptom[%d]: %r  (score=%.3f)", i, s, scored[i][0])

    return selected


