# powering follow-up questions without ever being displayed as a resolution.
DISPLAY_MIN_SCORE     = float(os.environ.get("DISPLAY_MIN_SCORE", "3.0"))
HIGH_CONFIDENCE       = float(os.environ.get("HIGH_CONFIDENCE", "3.0"))
TOP_K                 = int(os.environ.get("TOP_K", "10"))
