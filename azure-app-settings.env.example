# Azure App Service — Application Settings
# Set each of these in:
#   Azure Portal > App Service > Configuration > Application settings
#
# DO NOT commit real keys. This file is a reference only.

# Azure AI Search
SEARCH_ENDPOINT=https://vinny-outlook-ragsearch.search.windows.net
SEARCH_INDEX=multimodal-rag-1778857242111

# Azure Key Vault (secrets: search-api-key, tool-api-key are fetched from here at startup)
AZURE_KEY_VAULT_URL=https://vinny-kb-tool-vault.vault.azure.net

# Tuning
SPREAD_THRESHOLD=0.6
MIN_SCORE=1.0
TOP_K=5
RETURN_K=3

# Required: tells App Service which port your app listens on
WEBSITES_PORT=8000
